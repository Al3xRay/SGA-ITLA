                <!-- Campo Usuario -->
                <div class="login-form-group">
                    <label for="inputUsuario" class="form-label">Matrícula</label>
                    <input asp-for="Usuario"
                           class="form-control"
                           id="inputUsuario"
                           placeholder="Ej: 2024-2270"
                           autofocus
                           autocomplete="username" />
                    <span asp-validation-for="Usuario" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <!-- Campo Contraseña -->
                <div class="login-form-group">
                    <label for="inputContrasena" class="form-label">Contraseña</label>
                    <input asp-for="Contrasena"
                           class="form-control"
                           id="inputContrasena"
                           type="password"
                           placeholder="••••••••"
                           autocomplete="current-password" />
                    <span asp-validation-for="Contrasena" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <!-- Botón de acceso -->
                <button type="submit" class="btn-login" id="btnLogin">
                    Acceder al Sistema
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:0.5rem;">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </button>

            </form>

            <p style="text-align:center; margin-bottom:0.3rem; margin-top:1rem;">
                <span style="font-size:0.875rem; color:var(--text-secondary);">
                    ¿Primera vez en el sistema?
                </span>
                <a asp-action="Register" style="font-size:0.875rem; font-weight:600; color:var(--primary-mid); margin-left:0.35rem;">Registrarse</a>
            </p>

            <p class="login-footer-note">Instituto Tecnológico de las Américas &copy; @DateTime.Now.Year</p>
        </div>
    </div>

