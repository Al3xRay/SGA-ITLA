@using SGA.Web.Models.Personas
@model ConductorDto
@{ ViewData["Title"] = "Detalle — " + Model.NombreCompleto; }

<div class="row">
    <div class="col-lg-7">
        <div class="content-card">
            <div class="content-card-header bg-primary text-white p-3 rounded-top-4">
                <h5 class="mb-0 fw-bold"><i class="bi bi-person-vcard me-2"></i>@Model.NombreCompleto</h5>
            </div>
            <div class="content-card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted small">Documento</dt><dd class="col-sm-7">@Model.DocumentoIdentidad</dd>
                    <dt class="col-sm-5 text-muted small">Licencia</dt><dd class="col-sm-7">@Model.LicenciaConducir</dd>
                    <dt class="col-sm-5 text-muted small">Categoría</dt><dd class="col-sm-7">@Model.CategoriaLicencia</dd>
                    <dt class="col-sm-5 text-muted small">Vence Licencia</dt>
                    <dd class="col-sm-7 @(Model.FechaVencimientoLicencia < DateTime.Today ? "text-danger fw-bold" : "")">
                        @Model.FechaVencimientoLicencia.ToString("dd/MM/yyyy")
                        @if (Model.FechaVencimientoLicencia < DateTime.Today) { <span> ⚠️ VENCIDA</span> }
                    </dd>
                    <dt class="col-sm-5 text-muted small">Contratación</dt><dd class="col-sm-7">@Model.FechaContratacion.ToString("dd/MM/yyyy")</dd>
                    <dt class="col-sm-5 text-muted small">Teléfono</dt><dd class="col-sm-7">@(Model.Telefono ?? "—")</dd>
                </dl>
            </div>
        </div>
        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
        </div>
    </div>
</div>
