@using SGA.Web.ViewModels.Personas
@model PersonaListViewModel
@{ ViewData["Title"] = "Personas"; }

<div class="page-header">
    <div class="page-header-title">
        <h2>Directorio de Usuarios</h2>
        <p>Estudiantes, empleados y conductores registrados</p>
    </div>
    <div class="page-header-actions">
        <div style="position:relative;">
            <input type="text" id="personaSearch" class="form-control"
                   placeholder="Buscar nombre, documento..."
                   style="padding-left:2.25rem;min-width:220px;" />
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:var(--text-muted);">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
        </div>
        <a asp-action="Create" class="btn btn-primary" id="btn-nueva-persona">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Nueva Persona
        </a>
    </div>
</div>

<div class="table-container">
    @if (!Model.Personas.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
                </svg>
            </div>
            <h6>No hay personas registradas</h6>
            <p>Agrega usuarios para gestionar el acceso al servicio de transporte.</p>
            <a asp-action="Create" class="btn btn-primary btn-sm">Registrar persona</a>
        </div>
    }
    else
    {
        <div class="table-header">
            <h5>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.4rem;color:var(--primary-mid);">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                </svg>
                @Model.Personas.Count() usuarios
            </h5>
            <span style="font-size:0.8rem;color:var(--text-muted);">
                Activos: <strong style="color:var(--success);">@Model.Personas.Count(p => p.Activo)</strong>
            </span>
        </div>
        <div class="table-responsive">
            <table class="table" id="personasTable">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Documento</th>
                        <th>Tipo</th>
                        <th>Teléfono</th>
                        <th>Estado</th>
                        <th style="text-align:right;padding-right:1.5rem;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Personas)
                    {
                        var initials = string.Join("", (item.NombreCompleto ?? "U").Split(' ').Take(2).Select(s => s.Length > 0 ? s[0].ToString() : "")).ToUpper();
                        var tipoNombre = item.TipoPersonaNombre?.ToLower() ?? "";
                        string tipoBadge;
                        if (tipoNombre.Contains("estudiante")) tipoBadge = "badge-info-pill";
                        else if (tipoNombre.Contains("empleado")) tipoBadge = "badge-pendiente";
                        else tipoBadge = "badge-en-curso";
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:0.75rem;">
                                    <div class="avatar avatar-sm">@initials</div>
                                    <div>
                                        <div style="font-weight:600;color:var(--text-primary);">@item.NombreCompleto</div>
                                    </div>
                                </div>
                            </td>
                            <td style="color:var(--text-secondary);font-family:'Courier New',monospace;font-size:0.875rem;">@item.DocumentoIdentidad</td>
                            <td><span class="badge-status @tipoBadge">@item.TipoPersonaNombre</span></td>
                            <td style="color:var(--text-secondary);">@(item.Telefono ?? "—")</td>
                            <td>
                                <span class="badge-status @(item.Activo ? "badge-activo" : "badge-inactivo")">
                                    @(item.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td style="text-align:right;padding-right:1.25rem;">
                                <div style="display:flex;gap:0.375rem;justify-content:flex-end;">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-action-view" title="Ver detalles">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-action-edit" title="Editar">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.getElementById("personaSearch")?.addEventListener("keyup", function () {
            const f = this.value.toLowerCase();
            document.querySelectorAll("#personasTable tbody tr").forEach(r =>
                r.style.display = r.textContent.toLowerCase().includes(f) ? "" : "none");
        });
    </script>
}
