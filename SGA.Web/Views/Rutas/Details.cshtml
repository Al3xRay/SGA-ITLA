@using SGA.Web.Models.Transporte
@model RutaDto
@{ ViewData["Title"] = "Detalle — " + Model.Nombre; }

<div class="row">
    <div class="col-lg-7">
        <div class="content-card mb-3">
            <div class="content-card-header"><h5>@Model.Nombre</h5><span class="badge-status @(Model.Activo ? "badge-activo" : "badge-inactivo")">@(Model.Activo ? "Activo" : "Inactivo")</span></div>
            <div class="content-card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted small">Descripción</dt><dd class="col-sm-8">@Model.Descripcion</dd>
                    <dt class="col-sm-4 text-muted small">Origen</dt><dd class="col-sm-8">@Model.Origen</dd>
                    <dt class="col-sm-4 text-muted small">Destino</dt><dd class="col-sm-8">@Model.Destino</dd>
                    <dt class="col-sm-4 text-muted small">Duración</dt><dd class="col-sm-8">@Model.DuracionEstimada.ToString(@"hh\:mm") hrs</dd>
                    <dt class="col-sm-4 text-muted small">Paradas</dt><dd class="col-sm-8">@Model.Paradas.Count</dd>
                </dl>
            </div>
        </div>
        @if (Model.Paradas.Any())
        {
            <div class="content-card">
                <div class="content-card-header"><h5>Paradas</h5></div>
                <div class="content-card-body p-0">
                    <table class="table mb-0">
                        <thead><tr><th>#</th><th>Nombre</th><th>Ubicación</th><th>Tiempo desde origen</th></tr></thead>
                        <tbody>
                            @foreach (var p in Model.Paradas.OrderBy(x => x.Orden))
                            {
                                <tr><td>@p.Orden</td><td>@p.Nombre</td><td>@p.Ubicacion</td><td>@p.TiempoDesdeOrigen.ToString(@"hh\:mm")</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
        </div>
    </div>
</div>
