@using SGA.Web.ViewModels.Incidencias
@model IncidenciaListViewModel
@{ ViewData["Title"] = "Incidencias"; }

<div class="page-header">
    <div class="page-header-title">
        <h2>Gestión de Incidencias</h2>
        <p>Eventos reportados durante la ejecución del servicio de transporte</p>
    </div>
    <div class="page-header-actions">
        <div class="stat-card stat-danger" style="padding:0.75rem 1.25rem;gap:0.75rem;min-width:0;">
            <div style="width:32px;height:32px;background:var(--danger-bg);border-radius:var(--radius-xs);display:flex;align-items:center;justify-content:center;color:var(--danger);">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </div>
            <div class="stat-info-content">
                <span class="stat-label">Pendientes</span>
                <span style="font-size:1.375rem;font-weight:800;color:var(--danger);line-height:1;">@Model.Incidencias.Count(i => i.EstadoIncidenciaNombre != "Resuelta")</span>
            </div>
        </div>
        <div class="stat-card stat-success" style="padding:0.75rem 1.25rem;gap:0.75rem;min-width:0;">
            <div style="width:32px;height:32px;background:var(--success-bg);border-radius:var(--radius-xs);display:flex;align-items:center;justify-content:center;color:var(--success);">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                </svg>
            </div>
            <div class="stat-info-content">
                <span class="stat-label">Resueltas</span>
                <span style="font-size:1.375rem;font-weight:800;color:var(--success);line-height:1;">@Model.Incidencias.Count(i => i.EstadoIncidenciaNombre == "Resuelta")</span>
            </div>
        </div>
    </div>
</div>

<div style="display:flex;gap:0.25rem;margin-bottom:1.5rem;">
    <button class="btn btn-primary btn-sm" id="tab-pendientes" onclick="switchTab('pendientes')" style="border-radius:var(--radius-sm) 0 0 var(--radius-sm);">
        Pendientes
        <span style="background:rgba(255,255,255,0.25);padding:0.1rem 0.4rem;border-radius:99px;font-size:0.7rem;margin-left:0.35rem;">@Model.Incidencias.Count(i => i.EstadoIncidenciaNombre != "Resuelta")</span>
    </button>
    <button class="btn btn-outline-secondary btn-sm" id="tab-resueltas" onclick="switchTab('resueltas')" style="border-radius:0 var(--radius-sm) var(--radius-sm) 0;">
        Resueltas
        <span style="background:var(--bg-subtle);padding:0.1rem 0.4rem;border-radius:99px;font-size:0.7rem;margin-left:0.35rem;">@Model.Incidencias.Count(i => i.EstadoIncidenciaNombre == "Resuelta")</span>
    </button>
</div>

<div id="pane-pendientes">
    @await Html.PartialAsync("_IncidenciasTable", Model.Incidencias.Where(i => i.EstadoIncidenciaNombre != "Resuelta").ToList())
</div>
<div id="pane-resueltas" style="display:none;">
    @await Html.PartialAsync("_IncidenciasTable", Model.Incidencias.Where(i => i.EstadoIncidenciaNombre == "Resuelta").ToList())
</div>

@section Scripts {
    <script>
        function switchTab(tab) {
            const isPendiente = tab === 'pendientes';
            document.getElementById('pane-pendientes').style.display = isPendiente ? '' : 'none';
            document.getElementById('pane-resueltas').style.display = isPendiente ? 'none' : '';
            document.getElementById('tab-pendientes').className = isPendiente
                ? 'btn btn-primary btn-sm' : 'btn btn-outline-secondary btn-sm';
            document.getElementById('tab-resueltas').className = !isPendiente
                ? 'btn btn-primary btn-sm' : 'btn btn-outline-secondary btn-sm';
            document.getElementById('tab-pendientes').style.borderRadius = isPendiente ? 'var(--radius-sm) 0 0 var(--radius-sm)' : '0 var(--radius-sm) var(--radius-sm) 0';
            document.getElementById('tab-resueltas').style.borderRadius = !isPendiente ? 'var(--radius-sm) 0 0 var(--radius-sm)' : 'var(--radius-sm)';
        }
    </script>
}
