@using SGA.Web.ViewModels.Viajes
@model ViajeDetailViewModel
@{
    ViewData["Title"] = "Detalle del Viaje";
    var v = Model.Viaje;
    var pct = v.Capacidad > 0 ? (v.OcupacionActual * 100 / v.Capacidad) : 0;
    var badgeClass = v.EstadoViajeNombre switch { "En Curso" => "badge-activo", "Finalizado" => "badge-inactivo", _ => "badge-pendiente" };
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="content-card mb-3">
            <div class="content-card-header">
                <h5>Viaje #@v.Id — @v.RutaNombre</h5>
                <span class="badge-status @badgeClass">@v.EstadoViajeNombre</span>
            </div>
            <div class="content-card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Autobús</small>
                        <strong>@v.AutobusPlaca</strong>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Conductor</small>
                        <strong>@v.ConductorNombre</strong>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Fecha Programada</small>
                        <strong>@v.FechaProgramada.ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Inicio Real</small>
                        <strong>@(v.HoraInicioReal?.ToString("HH:mm") ?? "—")</strong>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Fin Real</small>
                        <strong>@(v.HoraFinReal?.ToString("HH:mm") ?? "—")</strong>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Observaciones</small>
                        <span>@(v.Observaciones ?? "—")</span>
                    </div>
                    <div class="col-12">
                        <small class="text-muted d-block mb-1">Ocupación: @v.OcupacionActual / @v.Capacidad</small>
                        <div class="progress" style="height:8px">
                            <div class="progress-bar bg-primary" style="width:@pct%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Acciones del viaje -->
        <div class="d-flex gap-2 flex-wrap">
            @if (v.EstadoViajeNombre == "Programado")
            {
                <form asp-action="Iniciar" asp-route-id="@v.Id" method="post">
                    <button type="submit" class="btn btn-success" onclick="return confirm('¿Iniciar este viaje?')">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                        Iniciar Viaje
                    </button>
                </form>
            }
            @if (v.EstadoViajeNombre == "En Curso")
            {
                <form asp-action="Finalizar" asp-route-id="@v.Id" method="post">
                    <button type="submit" class="btn btn-danger" onclick="return confirm('¿Finalizar este viaje?')">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><square x="3" y="3" width="18" height="18"/></svg>
                        Finalizar Viaje
                    </button>
                </form>
            }
            <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
        </div>
    </div>
</div>
