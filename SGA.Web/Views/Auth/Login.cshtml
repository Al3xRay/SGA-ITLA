                    <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
                        <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="1"/>
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#grid)"/>
                <circle cx="200" cy="150" r="120" fill="white" opacity="0.03"/>
                <circle cx="600" cy="450" r="200" fill="white" opacity="0.03"/>
                <circle cx="700" cy="100" r="80"  fill="white" opacity="0.04"/>
            </svg>
        </div>

        <div class="login-brand-content">
            <!-- Logo -->
            <div class="login-brand-logo">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="6" width="18" height="13" rx="2"/>
                    <path d="M3 11h18"/>
                    <circle cx="7" cy="19" r="1.5" fill="white" stroke="none"/>
                    <circle cx="17" cy="19" r="1.5" fill="white" stroke="none"/>
                    <path d="M8 6V4"/>
                    <path d="M16 6V4"/>
                </svg>
            </div>

            <h1 class="login-brand-title">SGA-ITLA</h1>
            <p class="login-brand-subtitle">Sistema de Gestión de Autobuses<br>del Instituto Tecnológico de las Américas</p>

