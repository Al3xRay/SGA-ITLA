@using SGA.Web.Models.Operaciones
@model SaveTransaccionFinancieraDto
@{
    ViewData["Title"] = "Registrar Nueva Transacción Financiera";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="form-card shadow-sm border-0 rounded-4">
            <div class="form-card-header bg-success text-white rounded-top-4 p-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="bi bi-cash-coin me-2"></i>Registrar Operación (Ingreso/Gasto)</h5>
            </div>
            
            <form asp-action="Create" method="post">
                <div class="form-card-body p-4">
                    <div asp-validation-summary="All" class="alert alert-danger alert-sm"></div>
                    
                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="Concepto" class="form-label fw-semibold">Concepto</label>
                            <input asp-for="Concepto" class="form-control" placeholder="Ej. Pago de Mantenimiento de Autobús 04" />
                            <span asp-validation-for="Concepto" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Tipo" class="form-label fw-semibold">Tipo de Transacción</label>
                            <select asp-for="Tipo" class="form-select">
                                <option value="Ingreso">Ingreso</option>
                                <option value="Gasto">Gasto Operativo</option>
                            </select>
                            <span asp-validation-for="Tipo" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Monto" class="form-label fw-semibold">Monto (RD$)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">RD$</span>
                                <input asp-for="Monto" class="form-control" type="number" step="0.01" min="0.01" />
                            </div>
                            <span asp-validation-for="Monto" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="MetodoPago" class="form-label fw-semibold">Método de Movimiento</label>
                            <select asp-for="MetodoPago" class="form-select">
                                <option value="Efectivo">Efectivo (Caja)</option>
                                <option value="Transferencia">Transferencia (Banco)</option>
                                <option value="Cheque">Cheque</option>
                            </select>
                            <span asp-validation-for="MetodoPago" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Referencia" class="form-label fw-semibold">Referencia (Opcional)</label>
                            <input asp-for="Referencia" class="form-control" placeholder="# Factura o Transacción" />
                            <span asp-validation-for="Referencia" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="form-card-footer bg-light rounded-bottom-4 p-3 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                    <button type="submit" class="btn btn-success px-4"><i class="bi bi-save2 me-2"></i>Registrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
