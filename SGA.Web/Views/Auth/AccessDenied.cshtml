@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = "_LayoutLogin";
}

<div class="login-wrapper">
    <div class="login-card text-center">
        <div class="mb-4">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#dc3545" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <line x1="15" y1="9" x2="9" y2="15"/>
                <line x1="9" y1="9" x2="15" y2="15"/>
            </svg>
        </div>
        <h2 class="mb-3">Acceso Denegado</h2>
        <p class="text-muted mb-4">No tiene permisos para acceder a esta sección.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Volver al Inicio</a>
    </div>
</div>
