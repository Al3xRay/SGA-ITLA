@using SGA.Web.ViewModels.Viajes
@model ViajeFormViewModel
@{ ViewData["Title"] = "Programar Viaje"; }

<div class="page-header">
    <div class="page-header-title">
        <h2>Programar Nuevo Viaje</h2>
        <p>Asigna ruta, autobús y conductor para el servicio de transporte</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3rem;">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Volver
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <form asp-action="Create" method="post" id="form-programar-viaje">
            <!-- ── Ruta ── -->
            <div class="form-card mb-3">
                <div class="form-card-header">
                    <div class="icon-badge icon-badge-primary">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="10" r="3"/>
                            <path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 10-16 0c0 3 2.7 7 8 11.7z"/>
                        </svg>
                    </div>
                    <h5>1 — Seleccionar Ruta</h5>
                </div>
                <div class="form-card-body">
                    <div asp-validation-summary="All" class="alert alert-danger alert-sm" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
                    <label asp-for="RutaId" class="form-label">Ruta de Transporte</label>
                    <select asp-for="RutaId" class="form-select" id="select-ruta" onchange="mostrarInfoRuta(this)">
                        <option value="">— Seleccione una ruta —</option>
                        @foreach (var r in Model.Rutas)
                        {
                            <option value="@r.Id" data-origen="@r.Origen" data-destino="@r.Destino" data-duracion="@r.DuracionEstimada">
                                @r.Nombre
                            </option>
                        }
                    </select>
                    <span asp-validation-for="RutaId" class="text-danger" style="font-size:0.8rem;"></span>

                    <!-- Preview de ruta seleccionada -->
                    <div id="rutaPreview" style="display:none;margin-top:0.875rem;padding:0.875rem 1rem;background:var(--bg-subtle);border-radius:var(--radius-sm);border:1px solid var(--border-color);">
                        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.75rem;">
                            <div style="display:flex;align-items:center;gap:0.5rem;">
                                <span style="font-size:0.8rem;font-weight:600;color:var(--text-muted);">Origen:</span>
                                <span id="rutaOrigen" style="font-weight:600;color:var(--text-primary);"></span>
                            </div>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--primary-mid);">
                                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                            </svg>
                            <div style="display:flex;align-items:center;gap:0.5rem;">
                                <span style="font-size:0.8rem;font-weight:600;color:var(--text-muted);">Destino:</span>
                                <span id="rutaDestino" style="font-weight:600;color:var(--text-primary);"></span>
                            </div>
                            <span class="badge-status badge-info-pill" style="margin-left:auto;" id="rutaDuracion"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Autobús + Conductor ── -->
            <div class="form-card mb-3">
                <div class="form-card-header">
                    <div class="icon-badge icon-badge-info">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 11h18"/>
                            <circle cx="7" cy="19" r="1.5" fill="currentColor" stroke="none"/>
                            <circle cx="17" cy="19" r="1.5" fill="currentColor" stroke="none"/>
                        </svg>
                    </div>
                    <h5>2 — Asignar Vehículo y Conductor</h5>
                </div>
                <div class="form-card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="AutobusId" class="form-label">Autobús</label>
                            <select asp-for="AutobusId" class="form-select" id="select-autobus">
                                <option value="">— Seleccione un autobús —</option>
                                @foreach (var a in Model.Autobuses)
                                {
                                    <option value="@a.Id">@a.Placa — @a.Marca @a.Modelo (@a.Capacidad pax)</option>
                                }
                            </select>
                            <span asp-validation-for="AutobusId" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConductorId" class="form-label">Conductor</label>
                            <select asp-for="ConductorId" class="form-select" id="select-conductor">
                                <option value="">— Seleccione un conductor —</option>
                                @foreach (var c in Model.Conductores)
                                {
                                    <option value="@c.Id">@c.NombreCompleto</option>
                                }
                            </select>
                            <span asp-validation-for="ConductorId" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Fecha y hora ── -->
            <div class="form-card mb-4">
                <div class="form-card-header">
                    <div class="icon-badge icon-badge-warning">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                    </div>
                    <h5>3 — Fecha y Hora de Salida</h5>
                </div>
                <div class="form-card-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="FechaProgramada" class="form-label">Fecha y Hora Programada</label>
                            <input asp-for="FechaProgramada" class="form-control" type="datetime-local" id="input-fecha-viaje" />
                            <span asp-validation-for="FechaProgramada" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Llegada Estimada</label>
                            <div id="llegadaEstimada" style="padding:0.6rem 0.875rem;background:var(--bg-subtle);border:1.5px solid var(--border-color);border-radius:var(--radius-sm);font-size:0.9rem;color:var(--text-muted);">
                                — selecciona fecha y ruta
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div style="display:flex;gap:0.75rem;justify-content:flex-end;">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                <button type="submit" class="btn btn-primary" id="btn-programar">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Programar Viaje
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Vista previa de ruta al seleccionar
        function mostrarInfoRuta(sel) {
            const opt = sel.selectedOptions[0];
            const preview = document.getElementById("rutaPreview");
            if (!opt || !opt.value) { preview.style.display = "none"; return; }
            document.getElementById("rutaOrigen").textContent  = opt.dataset.origen  || "—";
            document.getElementById("rutaDestino").textContent = opt.dataset.destino || "—";
            document.getElementById("rutaDuracion").textContent = "~" + (opt.dataset.duracion || "?") + " hrs";
            preview.style.display = "block";
            calcularLlegada();
        }

        // Calcula la llegada estimada
        function calcularLlegada() {
            const fechaInput  = document.getElementById("input-fecha-viaje").value;
            const rutaSel     = document.getElementById("select-ruta");
            const opt         = rutaSel.selectedOptions[0];
            const durStr      = opt?.dataset?.duracion;
            const llegadaEl   = document.getElementById("llegadaEstimada");

            if (!fechaInput || !durStr) { llegadaEl.textContent = "— selecciona fecha y ruta"; llegadaEl.style.color = "var(--text-muted)"; return; }

            const [h, m] = durStr.split(":").map(Number);
            const salida = new Date(fechaInput);
            salida.setHours(salida.getHours() + (h || 0), salida.getMinutes() + (m || 0));
            llegadaEl.textContent = salida.toLocaleTimeString("es-DO", { hour: "2-digit", minute: "2-digit" });
            llegadaEl.style.color = "var(--text-primary)";
            llegadaEl.style.fontWeight = "700";
        }

        document.getElementById("input-fecha-viaje")?.addEventListener("change", calcularLlegada);

        // Pre-fill min datetime to now
        const fechaInput = document.getElementById("input-fecha-viaje");
        if (fechaInput && !fechaInput.value) {
            const now = new Date();
            now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
            fechaInput.min = now.toISOString().slice(0, 16);
        }
    </script>
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
