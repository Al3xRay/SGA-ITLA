@using SGA.Web.ViewModels.Billetera
@model RutasPublicasViewModel
@{ ViewData["Title"] = "Rutas y Horarios"; }

<div class="page-header">
    <div class="page-header-title">
        <h2>Rutas y Horarios</h2>
        <p>Consulta las rutas disponibles del servicio de transporte institucional</p>
    </div>
</div>

<div style="background:linear-gradient(135deg,var(--primary) 0%,var(--primary-mid) 60%,var(--primary-light) 100%);
            border-radius:var(--radius-lg);padding:2rem;margin-bottom:1.75rem;
            position:relative;overflow:hidden;box-shadow:0 10px 30px rgba(30,58,138,0.3);">

    <div style="position:absolute;top:-60px;right:-60px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,0.06);"></div>
    <div style="position:absolute;bottom:-30px;right:160px;width:120px;height:120px;border-radius:50%;background:rgba(255,255,255,0.04);"></div>

    <div style="position:relative;z-index:1;max-width:560px;">
        <div style="font-size:0.8125rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:rgba(255,255,255,0.6);margin-bottom:0.5rem;">
            Transporte Institucional · ITLA
        </div>
        <h3 style="font-size:1.625rem;font-weight:800;color:white;letter-spacing:-0.025em;margin-bottom:1.25rem;">
            ¿A dónde quieres ir hoy?
        </h3>
        <form method="get" id="search-rutas-form">
            <div style="display:flex;gap:0.5rem;">
                <div style="position:relative;flex:1;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         style="position:absolute;left:0.875rem;top:50%;transform:translateY(-50%);color:rgba(255,255,255,0.5);pointer-events:none;">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input type="text" name="busqueda" id="inputBusqueda" value="@Model.Busqueda"
                           autocomplete="off"
                           style="width:100%;padding:0.75rem 1rem 0.75rem 2.75rem;border-radius:var(--radius-sm);
                                  border:1.5px solid rgba(255,255,255,0.25);background:rgba(255,255,255,0.12);
                                  color:white;font-size:0.9375rem;backdrop-filter:blur(4px);"
                           placeholder="Buscar por nombre, origen o destino..." />
                </div>
                <button type="submit" class="btn btn-primary" id="btn-buscar-ruta"
                        style="background:white;color:var(--primary-mid);border:none;font-weight:700;flex-shrink:0;">
                    Buscar
                </button>
                @if (!string.IsNullOrEmpty(Model.Busqueda))
                {
                    <a href="@Url.Action("Publicas", "Rutas")" id="btn-limpiar-ruta"
                       style="display:inline-flex;align-items:center;padding:0 0.875rem;border-radius:var(--radius-sm);
                              background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.8);font-weight:600;font-size:0.875rem;
                              text-decoration:none;border:1px solid rgba(255,255,255,0.2);">
                        ✕ Limpiar
                    </a>
                }
            </div>
        </form>
    </div>
</div>

@if (!Model.RutasFiltradas.Any())
{
    <div class="content-card">
        <div class="empty-state">
            <div class="empty-state-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 10-16 0c0 3 2.7 7 8 11.7z"/>
                </svg>
            </div>
            <h6>Sin resultados para "@Model.Busqueda"</h6>
            <p>Intenta con otro nombre, origen o destino.</p>
            <a href="@Url.Action("Publicas", "Rutas")" class="btn btn-outline-secondary btn-sm">Ver todas las rutas</a>
        </div>
    </div>
}
else
{
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
        <span style="font-size:0.8125rem;color:var(--text-muted);font-weight:600;">
            Mostrando <strong style="color:var(--text-primary);">@Model.RutasFiltradas.Count</strong> de @Model.Rutas.Count rutas disponibles
        </span>
        <div style="display:flex;gap:0.375rem;">
            <span class="badge-status badge-activo">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                @Model.RutasFiltradas.Count(r => r.Activo) activas
            </span>
        </div>
    </div>

    <div class="row g-3">
        @foreach (var ruta in Model.RutasFiltradas)
        {
            var paradaId = $"paradas_{ruta.Id}";
            <div class="col-xl-4 col-md-6">
                <div class="content-card" id="ruta-@ruta.Id" style="height:100%;display:flex;flex-direction:column;">

                    <!-- Cabecera -->
                    <div style="padding:1.125rem 1.25rem;border-bottom:1px solid var(--border-color);">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:0.875rem;gap:0.5rem;">
                            <div style="font-weight:800;font-size:1rem;color:var(--text-primary);line-height:1.3;">@ruta.Nombre</div>
                            <span class="badge-status @(ruta.Activo ? "badge-activo" : "badge-inactivo")" style="flex-shrink:0;">
                                @(ruta.Activo ? "Activa" : "Inactiva")
                            </span>
                        </div>

                        <!-- Línea Origen→Destino -->
                        <div style="display:flex;align-items:stretch;gap:0;border:1px solid var(--border-color);border-radius:var(--radius-sm);overflow:hidden;">
                            <div style="flex:1;padding:0.625rem 0.875rem;background:var(--success-bg);border-right:1px solid var(--border-color);">
                                <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:var(--success);margin-bottom:0.15rem;">Origen</div>
                                <div style="font-size:0.875rem;font-weight:700;color:var(--text-primary);line-height:1.2;">@ruta.Origen</div>
                            </div>
                            <div style="display:flex;align-items:center;padding:0 0.5rem;background:var(--bg-subtle);">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--text-muted);">
                                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                                </svg>
                            </div>
                            <div style="flex:1;padding:0.625rem 0.875rem;background:var(--danger-bg);">
                                <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:var(--danger);margin-bottom:0.15rem;">Destino</div>
                                <div style="font-size:0.875rem;font-weight:700;color:var(--text-primary);line-height:1.2;">@ruta.Destino</div>
                            </div>
                        </div>
                    </div>

                    <!-- Meta info -->
                    <div style="padding:0.75rem 1.25rem;display:flex;gap:1.25rem;border-bottom:1px solid var(--border-color);">
                        <div style="display:flex;align-items:center;gap:0.4rem;font-size:0.8125rem;color:var(--text-secondary);">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                            </svg>
                            <span><strong>~@ruta.DuracionEstimada.ToString(@"hh\:mm")</strong> hrs</span>
                        </div>
                        @if (ruta.Paradas.Any())
                        {
                            <div style="display:flex;align-items:center;gap:0.4rem;font-size:0.8125rem;color:var(--text-secondary);">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 10-16 0c0 3 2.7 7 8 11.7z"/>
                                </svg>
                                <span><strong>@ruta.Paradas.Count</strong> parada@(ruta.Paradas.Count != 1 ? "s" : "") intermedias</span>
                            </div>
                        }
                    </div>

                    <!-- Paradas colapsables -->
                    @if (ruta.Paradas.Any())
                    {
                        <div style="padding:0;margin-top:auto;">
                            <button type="button"
                                    onclick="toggleParadasPublica('@paradaId', this)"
                                    id="btn-paradas-@ruta.Id"
                                    style="width:100%;padding:0.75rem 1.25rem;background:none;border:none;border-top:1px solid var(--border-color);
                                           cursor:pointer;font-size:0.8125rem;font-weight:600;color:var(--primary-mid);
                                           display:flex;align-items:center;justify-content:space-between;">
                                <span style="display:flex;align-items:center;gap:0.4rem;">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                                    </svg>
                                    Ver itinerario completo
                                </span>
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="pub-chevron" style="transition:transform 0.22s ease;">
                                    <polyline points="6 9 12 15 18 9"/>
                                </svg>
                            </button>

                            <div id="@paradaId" style="display:none;padding:1rem 1.25rem;background:var(--bg-subtle);border-top:1px solid var(--border-color);">
                                <div style="position:relative;padding-left:1.375rem;">
                                    <div style="position:absolute;left:5px;top:6px;bottom:6px;width:1.5px;background:linear-gradient(to bottom,var(--success),var(--primary-mid),var(--danger));"></div>

                                    <!-- Origen -->
                                    <div style="position:relative;margin-bottom:0.75rem;">
                                        <div style="position:absolute;left:-1.375rem;top:3px;width:10px;height:10px;border-radius:50%;background:var(--success);box-shadow:0 0 0 3px var(--success-bg);"></div>
                                        <div style="font-size:0.8125rem;font-weight:700;color:var(--text-primary);">@ruta.Origen</div>
                                        <div style="font-size:0.7rem;color:var(--success);font-weight:600;">Punto de partida</div>
                                    </div>

                                    @foreach (var p in ruta.Paradas.OrderBy(x => x.Orden))
                                    {
                                        <div style="position:relative;margin-bottom:0.75rem;">
                                            <div style="position:absolute;left:-1.375rem;top:3px;width:8px;height:8px;border-radius:50%;background:var(--bg-card);border:2px solid var(--primary-mid);"></div>
                                            <div style="font-size:0.8125rem;font-weight:600;color:var(--text-primary);">@p.Nombre</div>
                                            <div style="font-size:0.7rem;color:var(--text-muted);">+@p.TiempoDesdeOrigen.ToString(@"hh\:mm") desde el origen</div>
                                        </div>
                                    }

                                    <!-- Destino -->
                                    <div style="position:relative;">
                                        <div style="position:absolute;left:-1.375rem;top:3px;width:10px;height:10px;border-radius:50%;background:var(--danger);box-shadow:0 0 0 3px var(--danger-bg);"></div>
                                        <div style="font-size:0.8125rem;font-weight:700;color:var(--text-primary);">@ruta.Destino</div>
                                        <div style="font-size:0.7rem;color:var(--danger);font-weight:600;">Llegada final · +@ruta.DuracionEstimada.ToString(@"hh\:mm")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Sin paradas intermedias -->
                        <div style="padding:0.625rem 1.25rem;margin-top:auto;border-top:1px solid var(--border-color);">
                            <span style="font-size:0.75rem;color:var(--text-muted);font-style:italic;">Sin paradas intermedias — servicio directo</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        function toggleParadasPublica(id, btn) {
            const panel   = document.getElementById(id);
            const chevron = btn.querySelector('.pub-chevron');
            const isOpen  = panel.style.display !== 'none';
            panel.style.display   = isOpen ? 'none' : 'block';
            chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
        }
    </script>
}
