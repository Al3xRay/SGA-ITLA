@using SGA.Web.Models.Personas
@model PersonaDto
@{ ViewData["Title"] = "Detalle — " + Model.NombreCompleto; }

<div class="row">
    <div class="col-lg-6">
        <div class="content-card mb-3">
            <div class="content-card-header"><h5>@Model.NombreCompleto</h5><span class="badge-status @(Model.Activo ? "badge-activo" : "badge-inactivo")">@(Model.Activo ? "Activo" : "Inactivo")</span></div>
            <div class="content-card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted small">Documento</dt><dd class="col-sm-8">@Model.DocumentoIdentidad</dd>
                    <dt class="col-sm-4 text-muted small">Tipo</dt><dd class="col-sm-8">@Model.TipoPersonaNombre</dd>
                    <dt class="col-sm-4 text-muted small">Teléfono</dt><dd class="col-sm-8">@(Model.Telefono ?? "—")</dd>
                    <dt class="col-sm-4 text-muted small">Dirección</dt><dd class="col-sm-8">@(Model.Direccion ?? "—")</dd>
                    <dt class="col-sm-4 text-muted small">Nacimiento</dt><dd class="col-sm-8">@(Model.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "—")</dd>
                    <dt class="col-sm-4 text-muted small">Registrado</dt><dd class="col-sm-8">@Model.FechaCreacion.ToString("dd/MM/yyyy")</dd>
                </dl>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
        </div>
    </div>
</div>
