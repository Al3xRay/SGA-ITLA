@model SGA.Web.ViewModels.Auth.RegisterViewModel
@{
    ViewData["Title"] = "Crear Cuenta";
    Layout = "_LayoutLogin";
}

<div class="login-page">

    <!-- Panel Izquierdo — Branding  -->
    <div class="login-brand-panel">
        <div class="login-brand-geo" aria-hidden="true">
            <svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
                        <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="1"/>
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#grid)"/>
                <circle cx="200" cy="150" r="120" fill="white" opacity="0.03"/>
                <circle cx="600" cy="450" r="200" fill="white" opacity="0.03"/>
                <circle cx="700" cy="100" r="80"  fill="white" opacity="0.04"/>
            </svg>
        </div>

        <div class="login-brand-content">
            <div class="login-brand-logo">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="6" width="18" height="13" rx="2"/>
                    <path d="M3 11h18"/>
                    <circle cx="7" cy="19" r="1.5" fill="white" stroke="none"/>
                    <circle cx="17" cy="19" r="1.5" fill="white" stroke="none"/>
                    <path d="M8 6V4"/>
                    <path d="M16 6V4"/>
                </svg>
            </div>
            <h1 class="login-brand-title">SGA-ITLA</h1>
            <p class="login-brand-subtitle">Únete a la plataforma tecnológica de transporte institucional</p>
        </div>
    </div>

    <!-- Panel Derecho — Formulario de Registro -->
    <div class="login-form-panel" style="overflow-y: auto;">
        <div class="login-form-container" style="max-width: 480px; padding: 2rem 0;">

            <div class="login-form-header">
                <h2>Crear Cuenta</h2>
                <p>Completa tus datos para registrarte</p>
            </div>

            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert alert-danger alert-sm mb-4" role="alert">
                    <span class="alert-icon">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                        </svg>
                    </span>
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form asp-action="Register" method="post" novalidate>
                
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <div class="login-form-group">
                            <label asp-for="Nombre" class="form-label"></label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Juan" autofocus />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="login-form-group">
                            <label asp-for="Apellido" class="form-label"></label>
                            <input asp-for="Apellido" class="form-control" placeholder="Ej: Pérez" />
                            <span asp-validation-for="Apellido" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="login-form-group">
                    <label asp-for="DocumentoIdentidad" class="form-label">Matrícula o Documento</label>
                    <input asp-for="DocumentoIdentidad" class="form-control" placeholder="Ej: 2023-1234" />
                    <span asp-validation-for="DocumentoIdentidad" class="text-danger small"></span>
                </div>

                <div class="login-form-group">
                    <label class="form-label">Tipo de Usuario</label>
                    <div class="role-selector" style="grid-template-columns: 1fr 1fr;">
                        <label class="role-option">
                            <input type="radio" asp-for="TipoPersonaId" value="1" checked />
                            <div class="role-card">
                                <div class="role-card-icon">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 6 3 6 3s6-1 6-3v-5"/>
                                    </svg>
                                </div>
                                Estudiante
                            </div>
                        </label>
                        <label class="role-option">
                            <input type="radio" asp-for="TipoPersonaId" value="2" />
                            <div class="role-card">
                                <div class="role-card-icon">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a4 4 0 00-8 0v2"/>
                                    </svg>
                                </div>
                                Empleado
                            </div>
                        </label>
                    </div>
                    <span asp-validation-for="TipoPersonaId" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="login-form-group">
                            <label asp-for="Contrasena" class="form-label"></label>
                            <input asp-for="Contrasena" type="password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="Contrasena" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="login-form-group">
                            <label asp-for="ConfirmarContrasena" class="form-label">Confirmar</label>
                            <input asp-for="ConfirmarContrasena" type="password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="ConfirmarContrasena" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-login">
                    Crear mi cuenta
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-left:0.5rem;">
                        <path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
                    </svg>
                </button>

            </form>

            <p style="text-align:center; margin-top:2rem; margin-bottom:0.3rem;">
                <span style="font-size:0.875rem; color:var(--text-secondary);">
                    ¿Ya tienes una cuenta?
                </span>
                <a asp-action="Login" style="font-size:0.875rem; font-weight:600; color:var(--primary-mid); margin-left:0.35rem;">Inicia Sesión</a>
            </p>

            <p class="login-footer-note">Instituto Tecnológico de las Américas &copy; @DateTime.Now.Year</p>
        </div>
    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}