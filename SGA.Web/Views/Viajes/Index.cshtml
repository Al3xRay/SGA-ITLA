@using SGA.Web.ViewModels.Viajes
@model ViajeListViewModel
@{ ViewData["Title"] = "Viajes"; }

<div class="page-header">
    <div class="page-header-title">
        <h2>Gestión de Viajes</h2>
        <p>Planificación y seguimiento de todos los servicios de transporte</p>
    </div>
    <div class="page-header-actions">
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
            <div style="position:relative;">
                <input type="text" id="viajeSearch" class="form-control"
                       placeholder="Buscar ruta, conductor..."
                       style="padding-left:2.25rem;min-width:260px;" />
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:var(--text-muted);">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
            </div>
            <select id="rutaFilter" class="form-select" style="min-width:180px;">
                <option value="">Todas las rutas</option>
                @foreach (var ruta in Model.Viajes.Select(v => v.RutaNombre).Distinct().OrderBy(r => r))
                {
                    <option value="@ruta">@ruta</option>
                }
            </select>
        </div>
        <a asp-action="Create" class="btn btn-primary" id="btn-programar-viaje" style="white-space:nowrap;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Programar Viaje
        </a>
    </div>
</div>

<div class="table-container">
    @if (!Model.Viajes.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </div>
            <h6>Sin viajes programados</h6>
            <p>Planifica el primer servicio de transporte asignando ruta, bus y conductor.</p>
            <a asp-action="Create" class="btn btn-primary btn-sm">Programar viaje</a>
        </div>
    }
    else
    {
        <div class="table-header">
            <h5>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.4rem;color:var(--primary-mid);">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                @Model.Viajes.Count() viajes
            </h5>
        </div>
        <div class="table-responsive">
            <table class="table" id="viajesTable">
                <thead>
                    <tr>
                        <th>Ruta</th>
                        <th>Autobús</th>
                        <th>Conductor</th>
                        <th>Fecha Programada</th>
                        <th>Ocupación</th>
                        <th style="text-align:center;">Estado</th>
                        <th style="text-align:right;padding-right:1.5rem;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Viajes)
                    {
                        var pct = item.Capacidad > 0 ? (item.OcupacionActual * 100 / item.Capacidad) : 0;
                        var estadoNombre = item.EstadoViajeNombre?.ToLower() ?? "";
                        string estadoClass;
                        if (estadoNombre.Contains("curso")) estadoClass = "badge-en-curso";
                        else if (estadoNombre.Contains("finaliz")) estadoClass = "badge-activo";
                        else if (estadoNombre.Contains("cancel")) estadoClass = "badge-inactivo";
                        else if (estadoNombre.Contains("retras")) estadoClass = "badge-pendiente";
                        else estadoClass = "badge-info-pill";

                        <tr>
                            <td class="ruta-cell" style="font-weight:600;color:var(--text-primary);">@item.RutaNombre</td>
                            <td style="font-family:'Courier New',monospace;font-size:0.875rem;color:var(--text-secondary);">@item.AutobusPlaca</td>
                            <td style="color:var(--text-secondary);">@item.ConductorNombre</td>
                            <td style="color:var(--text-secondary);white-space:nowrap;">@item.FechaProgramada.ToString("dd/MM/yyyy HH:mm")</td>
                            <td style="min-width:130px;">
                                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.25rem;">
                                    <span style="font-weight:700;font-size:0.8125rem;">@item.OcupacionActual</span>
                                    <span style="font-size:0.75rem;color:var(--text-muted);">/ @item.Capacidad pax</span>
                                </div>
                                <div style="height:5px;background:var(--bg-subtle);border-radius:99px;overflow:hidden;">
                                    <div style="height:100%;width:@pct%;background:@(pct >= 100 ? "var(--danger)" : pct > 75 ? "var(--warning)" : "var(--primary-mid)");border-radius:99px;transition:width 0.3s ease;"></div>
                                </div>
                            </td>
                            <td style="text-align:center;">
                                @if (item.TieneIncidencias)
                                {
                                    <span class="badge-status badge-inactivo">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:0.2rem;"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
                                        Incidencias
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-status @estadoClass">@item.EstadoViajeNombre</span>
                                }
                            </td>
                            <td style="text-align:right;padding-right:1.25rem;">
                                <div style="display:flex;gap:0.375rem;justify-content:flex-end;">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-action-view" title="Ver detalles">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline"
                                          onsubmit="return confirm('¿Eliminar este viaje?')">
                                        <button type="submit" class="btn-action btn-action-danger" title="Eliminar">
                                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const routeFilter = document.getElementById("rutaFilter");
            const textSearch = document.getElementById("viajeSearch");
            function filterTable() {
                const rt = routeFilter?.value.toLowerCase() || "";
                const txt = textSearch?.value.toLowerCase() || "";
                document.querySelectorAll("#viajesTable tbody tr").forEach(row => {
                    const routeCell = row.querySelector(".ruta-cell")?.innerText.toLowerCase() || "";
                    const content = row.innerText.toLowerCase();
                    row.style.display = ((!rt || routeCell.includes(rt)) && (!txt || content.includes(txt))) ? "" : "none";
                });
            }
            routeFilter?.addEventListener("change", filterTable);
            textSearch?.addEventListener("keyup", filterTable);
        });
    </script>
}
