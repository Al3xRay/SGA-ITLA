@using SGA.Web.Models.Transporte
@using SGA.Web.Models.Operaciones
@model SGA.Web.ViewModels.Auditoria.AuditoriaDashboardViewModel
@{
    ViewData["Title"] = "Auditoría";
    var totalViajes     = Model.Viajes.Count;
    var totalPermitidos = Model.Viajes.Sum(x => x.Pasajeros.Count(p => p.AccesoPermitido));
    var totalDenegados  = Model.Viajes.Sum(x => x.Pasajeros.Count(p => !p.AccesoPermitido));
    var totalRegistros  = totalPermitidos + totalDenegados;
    var pctAprobados    = totalRegistros > 0 ? (totalPermitidos * 100.0 / totalRegistros) : 0;

    var totalEmisiones = Model.Emisiones.Count;
    var totalRecaudado = Model.Emisiones.Sum(x => x.MontoCobrado);
    var usosTotales = Model.Emisiones.Sum(x => x.Consumos.Count);
}

<div class="page-header">
    <div class="page-header-title">
        <h2>Auditoría y Trazabilidad</h2>
        <p>Historial operativo y financiero del sistema</p>
    </div>
    <div class="page-header-actions">
    </div>
</div>

<ul class="nav nav-pills mb-4" id="auditoriaTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="viajes-tab" data-bs-toggle="pill" data-bs-target="#viajes" type="button" role="tab" aria-controls="viajes" aria-selected="true">Operación</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="emisiones-tab" data-bs-toggle="pill" data-bs-target="#emisiones" type="button" role="tab" aria-controls="emisiones" aria-selected="false">Financiero</button>
  </li>
</ul>

<div class="tab-content" id="auditoriaTabsContent">
    <!-- PESTAÑA DE VIAJES -->
    <div class="tab-pane fade show active" id="viajes" role="tabpanel" aria-labelledby="viajes-tab">
        <div style="display:flex;justify-content:flex-end;margin-bottom:1rem;">
            <div style="position:relative;">
                <input type="text" id="viajesSearch" class="form-control"
                       placeholder="Buscar ruta, conductor, placa..."
                       style="padding-left:2.25rem;min-width:240px;" />
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-3 col-sm-6">
                <div class="stat-card stat-primary">
                    <div class="stat-info-content">
                        <span class="stat-label">Viajes Auditados</span>
                        <span class="stat-value">@totalViajes</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-card stat-info">
                    <div class="stat-info-content">
                        <span class="stat-label">Total Interacciones</span>
                        <span class="stat-value">@totalRegistros</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-card stat-success">
                    <div class="stat-info-content">
                        <span class="stat-label">Accesos Permitidos</span>
                        <span class="stat-value">@totalPermitidos</span>
                        <small style="font-size:0.75rem;color:var(--success);">@pctAprobados.ToString("N0")% de éxito</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-card stat-danger">
                    <div class="stat-info-content">
                        <span class="stat-label">Accesos Denegados</span>
                        <span class="stat-value">@totalDenegados</span>
                    </div>
                </div>
            </div>
        </div>

        @if (!Model.Viajes.Any())
        {
            <div class="content-card">
                <div class="empty-state">
                    <h6>Sin registros de auditoría</h6>
                    <p>Los viajes realizados irán generando el historial de accesos automáticamente.</p>
                </div>
            </div>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:0.75rem;" id="viajesList">
                @foreach (var item in Model.Viajes.OrderByDescending(x => x.Viaje.FechaProgramada))
                {
                    var totalPas  = item.Pasajeros.Count;
                    var denegados = item.Pasajeros.Count(p => !p.AccesoPermitido);
                    var auditId   = $"viaje_{item.Viaje.Id}";

                    <div class="content-card viaje-item" style="margin-bottom:0;">
                        <div role="button" onclick="toggleAudit('@auditId', this)"
                             style="display:flex;align-items:center;justify-content:space-between;padding:1.125rem 1.5rem;cursor:pointer;gap:1rem;user-select:none;">
                            <div style="display:flex;align-items:center;gap:1.25rem;flex:1;min-width:0;">
                                <div style="text-align:center;flex-shrink:0;min-width:56px;padding-right:1.25rem;border-right:1px solid var(--border-color);">
                                    <div style="font-size:0.6875rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;">Viaje</div>
                                    <div style="font-size:1.375rem;font-weight:800;color:var(--text-primary);line-height:1.1;">#@item.Viaje.Id</div>
                                </div>
                                <div style="flex:1;min-width:0;">
                                    <div style="font-weight:700;font-size:0.9375rem;color:var(--text-primary);margin-bottom:0.2rem;" class="searchable">
                                        @item.Viaje.RutaNombre
                                    </div>
                                    <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
                                        <span style="font-size:0.8rem;color:var(--text-secondary);" class="searchable">@item.Viaje.ConductorNombre</span>
                                        <span style="font-size:0.8rem;color:var(--text-secondary);" class="searchable">@item.Viaje.AutobusPlaca</span>
                                        <span style="font-size:0.8rem;color:var(--text-muted);">@item.Viaje.FechaProgramada.ToString("dd/MM/yyyy")</span>
                                    </div>
                                </div>
                            </div>
                            <div style="display:flex;align-items:center;gap:1.25rem;flex-shrink:0;">
                                <div style="text-align:right;">
                                    <div style="font-weight:700;font-size:0.9rem;color:var(--text-primary);">@totalPas interacciones</div>
                                    <span class="badge-status @(denegados > 0 ? "badge-inactivo" : "badge-activo")" style="font-size:0.6875rem;">
                                        @(denegados > 0 ? $"{denegados} rechazados" : "Sin rechazos")
                                    </span>
                                </div>
                                <div class="audit-chevron" style="color:var(--text-muted);transition:transform 0.25s ease;">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="6 9 12 15 18 9"/>
                                    </svg>
                                </div>
                            </div>
                        </div>

                        <div id="@auditId" style="display:none;border-top:1px solid var(--border-color);">
                            <div style="padding:1.25rem 1.5rem;background:var(--bg-subtle);">
                                @if (!item.Pasajeros.Any())
                                {
                                    <p style="font-size:0.875rem;color:var(--text-muted);font-style:italic;">No hay registros de acceso procesados en este viaje.</p>
                                }
                                else
                                {
                                    <div style="max-height:320px;overflow-y:auto;display:flex;flex-direction:column;gap:0.375rem;">
                                        @foreach (var pas in item.Pasajeros.OrderByDescending(p => p.FechaUso))
                                        {
                                            var isOk = pas.AccesoPermitido;
                                            <div style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem 1rem;background:var(--bg-card);border-radius:var(--radius-sm);border-left:3px solid @(isOk ? "var(--success)" : "var(--danger)");gap:1rem;">
                                                <div style="display:flex;align-items:center;gap:0.875rem;flex:1;min-width:0;">
                                                    <span class="badge-status @(isOk ? "badge-activo" : "badge-inactivo")" style="flex-shrink:0;">
                                                        @(isOk ? "Permitido" : "Rechazado")
                                                    </span>
                                                    <div style="min-width:0;">
                                                        <div style="font-weight:600;font-size:0.875rem;color:var(--text-primary);" class="searchable">@pas.PersonaNombre [@pas.PersonaMatricula]</div>
                                                        <div style="font-size:0.75rem;color:var(--text-muted);" class="searchable">@pas.PersonaDocumento · @pas.TipoViaje</div>
                                                    </div>
                                                </div>
                                                <div style="font-size:0.75rem;color:var(--text-muted);flex-shrink:0;font-family:'Courier New',monospace;">
                                                    @pas.FechaUso.ToString("HH:mm:ss")
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- PESTAÑA DE EMISIONES -->
    <div class="tab-pane fade" id="emisiones" role="tabpanel" aria-labelledby="emisiones-tab">
        <div style="display:flex;justify-content:flex-end;margin-bottom:1rem;">
            <div style="position:relative;">
                <input type="text" id="emisionesSearch" class="form-control"
                       placeholder="Buscar emisor, receptor, tipo..."
                       style="padding-left:2.25rem;min-width:240px;" />
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-card stat-primary">
                    <div class="stat-info-content">
                        <span class="stat-label">Tickets Emitidos</span>
                        <span class="stat-value">@totalEmisiones</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card stat-success">
                    <div class="stat-info-content">
                        <span class="stat-label">Ingresos Monetarios</span>
                        <span class="stat-value text-success">RD$ @totalRecaudado.ToString("N2")</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card stat-info">
                    <div class="stat-info-content">
                        <span class="stat-label">Total Validaciones</span>
                        <span class="stat-value">@usosTotales</span>
                    </div>
                </div>
            </div>
        </div>

        @if (!Model.Emisiones.Any())
        {
            <div class="content-card">
                <div class="empty-state">
                    <h6>No hay emisiones de tickets registradas.</h6>
                </div>
            </div>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:0.75rem;" id="emisionesList">
                @foreach (var emision in Model.Emisiones.OrderByDescending(x => x.FechaEmision))
                {
                    var emiId = $"emision_{emision.EmisionId}";
                    var valido = emision.FechaVencimiento > DateTime.UtcNow;

                    <div class="content-card emision-item" style="margin-bottom:0;">
                        <div role="button" onclick="toggleAudit('@emiId', this)"
                             style="display:flex;align-items:center;justify-content:space-between;padding:1.125rem 1.5rem;cursor:pointer;gap:1rem;user-select:none;">
                            <div style="display:flex;align-items:center;gap:1.25rem;flex:1;min-width:0;">
                                <div style="text-align:center;flex-shrink:0;min-width:56px;padding-right:1.25rem;border-right:1px solid var(--border-color);">
                                    <div style="font-size:0.6875rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;">Ticket</div>
                                    <div style="font-size:1.375rem;font-weight:800;color:var(--text-primary);line-height:1.1;">#@emision.EmisionId</div>
                                </div>
                                <div style="flex:1;min-width:0;">
                                    <div style="font-weight:700;font-size:0.9375rem;color:var(--text-primary);margin-bottom:0.2rem;" class="searchable">
                                        Receptor: @emision.TitularNombre [@emision.TitularMatricula] (@emision.TitularDocumento)
                                    </div>
                                    <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
                                        <span style="font-size:0.8rem;color:var(--text-secondary);" class="searchable">
                                            <strong>Emitido Por:</strong> @emision.EmisorNombre
                                        </span>
                                        <span style="font-size:0.8rem;color:var(--text-secondary);" class="searchable">
                                            @emision.TipoAutorizacion
                                        </span>
                                        <span style="font-size:0.8rem;color:@(valido ? "var(--success)" : "var(--text-muted)");">
                                            Vence: @emision.FechaVencimiento.ToString("dd/MM/yyyy")
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div style="display:flex;align-items:center;gap:1.25rem;flex-shrink:0;">
                                <div style="text-align:right;">
                                    <div style="font-weight:800;font-size:1rem;color:var(--success);">
                                        RD$ @emision.MontoCobrado.ToString("N2")
                                    </div>
                                    <span class="badge-status badge-info" style="font-size:0.6875rem;">
                                        @emision.Consumos.Count Usos Registrados
                                    </span>
                                </div>
                                <div class="audit-chevron" style="color:var(--text-muted);transition:transform 0.25s ease;">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="6 9 12 15 18 9"/>
                                    </svg>
                                </div>
                            </div>
                        </div>

                        <div id="@emiId" style="display:none;border-top:1px solid var(--border-color);">
                            <div style="padding:1.25rem 1.5rem;background:var(--bg-subtle);">
                                @if (!emision.Consumos.Any())
                                {
                                    <p style="font-size:0.875rem;color:var(--text-muted);font-style:italic;">El ticket no ha sido escaneado aún.</p>
                                }
                                else
                                {
                                    <div style="max-height:320px;overflow-y:auto;display:flex;flex-direction:column;gap:0.375rem;">
                                        @foreach (var uso in emision.Consumos.OrderByDescending(p => p.FechaUso))
                                        {
                                            <div style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem 1rem;background:var(--bg-card);border-radius:var(--radius-sm);border-left:3px solid var(--info);gap:1rem;">
                                                <div style="display:flex;align-items:center;gap:0.875rem;flex:1;min-width:0;">
                                                    <div style="min-width:0;">
                                                        <div style="font-weight:600;font-size:0.875rem;color:var(--text-primary);">Trazabilidad de Consumo al Subir</div>
                                                    </div>
                                                </div>
                                                <div style="font-size:0.75rem;color:var(--text-muted);flex-shrink:0;font-family:'Courier New',monospace;">
                                                    @uso.FechaUso.ToString("dd/MM/yyyy HH:mm:ss")
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function toggleAudit(id, btn) {
            const panel = document.getElementById(id);
            if (!panel) return;
            
            const isOpen = panel.style.display !== 'none';
            panel.style.display = isOpen ? 'none' : 'block';
            
            const chevron = btn.querySelector('.audit-chevron');
            if (chevron) {
                chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
            }
        }

        document.getElementById("viajesSearch")?.addEventListener("keyup", function () {
            const f = this.value.toLowerCase();
            document.querySelectorAll(".viaje-item").forEach(card => {
                const texts = [...card.querySelectorAll(".searchable")].map(t => t.textContent.toLowerCase()).join(" ");
                card.style.display = texts.includes(f) ? "" : "none";
            });
        });

        document.getElementById("emisionesSearch")?.addEventListener("keyup", function () {
            const f = this.value.toLowerCase();
            document.querySelectorAll(".emision-item").forEach(card => {
                const texts = [...card.querySelectorAll(".searchable")].map(t => t.textContent.toLowerCase()).join(" ");
                card.style.display = texts.includes(f) ? "" : "none";
            });
        });
    </script>
}
