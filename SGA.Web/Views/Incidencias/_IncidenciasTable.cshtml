@using SGA.Web.Models.Operaciones
@model List<IncidenciaDto>

@if (!Model.Any())
{
    <div class="empty-state text-center py-5">
        <i class="bi bi-check-circle display-4 text-muted mb-3"></i>
        <h6 class="text-secondary fw-semibold">No hay incidencias en esta categoría.</h6>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light"><tr><th class="ps-3 border-0">Tipo</th><th class="border-0">Viaje</th><th class="border-0">Reportado Por</th><th class="border-0">Fecha</th><th class="border-0">Grave</th><th class="text-end border-0 pe-3">Acciones</th></tr></thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3 fw-medium">
                            <span class="badge @(item.EsGrave ? "bg-danger" : "bg-warning text-dark")">@item.TipoIncidenciaNombre</span>
                        </td>
                        <td>Viaje #@item.ViajeId</td>
                        <td><small><i class="bi bi-person me-1"></i>@item.ReportadoPorNombre</small></td>
                        <td><i class="bi bi-clock me-1"></i>@item.FechaReporte.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            @if(item.EsGrave) { <i class="bi bi-exclamation-triangle-fill text-danger" title="Incidencia Grave"></i> }
                        </td>
                        <td class="text-end pe-3">
                            <div class="d-flex gap-2 justify-content-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-action-view" title="Detalles">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                </a>
                                @if (item.EstadoIncidenciaNombre != "Resuelta")
                                {
                                    <a asp-action="Resolver" asp-route-id="@item.Id" class="btn-action btn-action-success" title="Marcar como Resuelta">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
