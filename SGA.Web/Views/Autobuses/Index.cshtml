@using SGA.Web.ViewModels.Autobuses
@model AutobusListViewModel
@{
    ViewData["Title"] = "Autobuses";
}

<div class="page-header">
    <div class="page-header-title">
        <h2>Flota de Autobuses</h2>
        <p>Administra los vehículos institucionales del ITLA</p>
    </div>
    <div class="page-header-actions">
        <div style="position:relative;">
            <input type="text" id="busSearchInput" class="form-control"
                   placeholder="Buscar placa, marca..."
                   style="padding-left:2.25rem; min-width:220px;" />
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:var(--text-muted);">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
        </div>
        <a asp-action="Create" class="btn btn-primary" id="btn-nuevo-autobus">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Nuevo Autobús
        </a>
    </div>
</div>

<div class="table-container">
    @if (!Model.Autobuses.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 11h18"/>
                    <circle cx="7" cy="19" r="1.5" fill="currentColor" stroke="none"/>
                    <circle cx="17" cy="19" r="1.5" fill="currentColor" stroke="none"/>
                </svg>
            </div>
            <h6>Sin autobuses registrados</h6>
            <p>Comienza agregando el primer vehículo de la flota institucional.</p>
            <a asp-action="Create" class="btn btn-primary btn-sm">Registrar primer autobús</a>
        </div>
    }
    else
    {
        <div class="table-header">
            <h5>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.4rem;color:var(--primary-mid);">
                    <rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 11h18"/>
                    <circle cx="7" cy="19" r="1.5" fill="currentColor" stroke="none"/>
                    <circle cx="17" cy="19" r="1.5" fill="currentColor" stroke="none"/>
                </svg>
                @Model.Autobuses.Count() vehículos registrados
            </h5>
            <span style="font-size:0.8rem;color:var(--text-muted);">
                Activos: <strong style="color:var(--success);">@Model.Autobuses.Count(a => a.Activo)</strong>
            </span>
        </div>
        <div class="table-responsive">
            <table class="table" id="busTable">
                <thead>
                    <tr>
                        <th>Placa</th>
                        <th>Marca / Modelo</th>
                        <th>Capacidad</th>
                        <th>Estado Operativo</th>
                        <th>Activo</th>
                        <th style="text-align:right; padding-right:1.5rem;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Autobuses)
                    {
                        var statusName = item.EstadoAutobusNombre?.ToLower() ?? "";
                        string stClass;
                        if (statusName.Contains("disponible")) stClass = "badge-activo";
                        else if (statusName.Contains("mantenimiento")) stClass = "badge-pendiente";
                        else stClass = "badge-inactivo";

                        <tr>
                            <td>
                                <span style="font-weight:700;font-size:0.9375rem;letter-spacing:0.02em;color:var(--text-primary);">
                                    @item.Placa
                                </span>
                            </td>
                            <td>
                                <span style="font-weight:500;">@item.Marca</span>
                                <span style="color:var(--text-muted);"> @item.Modelo</span>
                            </td>
                            <td>
                                <span class="badge-status badge-info-pill">@item.Capacidad pax</span>
                            </td>
                            <td>
                                <span class="badge-status @stClass">@item.EstadoAutobusNombre</span>
                            </td>
                            <td>
                                <span class="badge-status @(item.Activo ? "badge-activo" : "badge-inactivo")">
                                    @(item.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td style="text-align:right;padding-right:1.25rem;">
                                <div style="display:flex;gap:0.375rem;justify-content:flex-end;">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-action-view" title="Ver detalles">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                                        </svg>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-action-edit" title="Editar">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                                            <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                        </svg>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline"
                                          onsubmit="return confirm('¿Eliminar el autobús @item.Placa?')">
                                        <button type="submit" class="btn-action btn-action-danger" title="Eliminar">
                                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="3 6 5 6 21 6"/>
                                                <path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/>
                                                <path d="M9 6V4h6v2"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.getElementById("busSearchInput")?.addEventListener("keyup", function () {
            const f = this.value.toLowerCase();
            document.querySelectorAll("#busTable tbody tr").forEach(r =>
                r.style.display = r.textContent.toLowerCase().includes(f) ? "" : "none");
        });
    </script>
}
