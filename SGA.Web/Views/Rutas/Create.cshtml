@using SGA.Web.ViewModels.Rutas
@model RutaFormViewModel
@{ ViewData["Title"] = "Nueva Ruta y Horarios"; }

<div class="page-header">
    <div class="page-header-title">
        <h2>Trazar Nueva Ruta</h2>
        <p>Define el trayecto, tiempos estimados y paradas del autobús</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3rem;">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Volver
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-9">
        <form asp-action="Create" method="post" id="rutaForm">
            <div class="form-card mb-4">
                <div class="form-card-header">
                    <div class="icon-badge icon-badge-primary">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="10" r="3"/>
                            <path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 10-16 0c0 3 2.7 7 8 11.7z"/>
                        </svg>
                    </div>
                    <h5>Datos Generales de la Ruta</h5>
                </div>
                <div class="form-card-body">
                    <div asp-validation-summary="All" class="alert alert-danger alert-sm" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
                    
                    <div class="row g-4">
                        <div class="col-md-7">
                            <label asp-for="Nombre" class="form-label">Nombre de la Ruta</label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Ruta 2 - Las Américas" />
                            <span asp-validation-for="Nombre" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-md-5">
                            <label asp-for="DuracionEstimadaStr" class="form-label">Duración Total Estimada</label>
                            <div style="position:relative;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" 
                                     style="position:absolute;left:0.875rem;top:50%;transform:translateY(-50%);color:var(--text-muted);">
                                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                                </svg>
                                <input asp-for="DuracionEstimadaStr" class="form-control" placeholder="00:00:00" style="padding-left:2.5rem;" />
                            </div>
                            <span asp-validation-for="DuracionEstimadaStr" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Descripcion" class="form-label">Descripción <span style="color:var(--text-muted);font-weight:400;">(Opcional)</span></label>
                            <textarea asp-for="Descripcion" class="form-control" rows="2" placeholder="Detalles de la operación..."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-section-label" style="margin-bottom:0.75rem;">Trayecto Principal</div>
                            <div style="display:flex;flex-direction:column;gap:0.75rem;background:var(--bg-subtle);padding:1rem;border-radius:var(--radius-sm);border:1px solid var(--border-color);">
                                
                                <div style="display:flex;align-items:flex-start;gap:1rem;">
                                    <div style="display:flex;flex-direction:column;align-items:center;margin-top:0.6rem;flex-shrink:0;">
                                        <div style="width:12px;height:12px;border-radius:50%;background:var(--success);box-shadow:0 0 0 3px var(--success-bg);"></div>
                                        <div style="width:2px;height:38px;background:var(--border-strong);margin:4px 0;"></div>
                                        <div style="width:12px;height:12px;border-radius:50%;background:var(--danger);box-shadow:0 0 0 3px var(--danger-bg);"></div>
                                    </div>
                                    <div style="flex:1;">
                                        <div style="margin-bottom:1rem;">
                                            <input asp-for="Origen" class="form-control form-control-sm" placeholder="Origen: Ej: Megacentro (Punto de Salida)" style="font-weight:600;" />
                                            <span asp-validation-for="Origen" class="text-danger" style="font-size:0.75rem;"></span>
                                        </div>
                                        <div>
                                            <input asp-for="Destino" class="form-control form-control-sm" placeholder="Destino: Ej: ITLA (Punto Final)" style="font-weight:600;" />
                                            <span asp-validation-for="Destino" class="text-danger" style="font-size:0.75rem;"></span>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-card mb-4" id="contenedorParadas">
                <div class="form-card-header">
                    <div style="display:flex;align-items:center;gap:0.75rem;width:100%;">
                        <div class="icon-badge icon-badge-info">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
                                <path d="M8 12h.01"/><path d="M16 12h.01"/>
                            </svg>
                        </div>
                        <h5 style="margin:0;">Paradas Intermedias</h5>
                        <button type="button" class="btn btn-outline-primary btn-sm ml-auto" id="btnAddParada" style="margin-left:auto;">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:0.2rem;">
                                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                            Añadir Parada
                        </button>
                    </div>
                </div>
                <div class="form-card-body">
                    <div id="paradasContainer">
                        <div class="empty-state" id="paradasEmpty" style="padding:1.5rem 0;">
                            <div class="empty-state-icon" style="width:40px;height:40px;margin-bottom:0.75rem;">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/>
                                </svg>
                            </div>
                            <h6 style="margin-bottom:0.25rem;">Sin paradas intermedias</h6>
                            <p style="margin:0;">Esta será una ruta de viaje directo (Origen a Destino). Haz clic en 'Añadir Parada' si se requiere.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div style="display:flex;justify-content:flex-end;gap:0.75rem;margin-bottom:2rem;">
               <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
               <button type="submit" class="btn btn-primary">
                   <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3rem;">
                       <polyline points="20 6 9 17 4 12"/>
                   </svg>
                   Crear Ruta
               </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const container = document.getElementById('paradasContainer');
            const emptyLabel = document.getElementById('paradasEmpty');
            const btnAdd = document.getElementById('btnAddParada');
            let paradasCount = 0;

            btnAdd.addEventListener('click', () => {
                if(paradasCount === 0) emptyLabel.style.display = 'none';
                
                const itemDiv = document.createElement('div');
                itemDiv.className = 'parada-item';
                itemDiv.style.cssText = 'position:relative;margin-bottom:0.75rem;padding:0.875rem 1rem;background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-sm);display:flex;gap:1.25rem;align-items:flex-start;box-shadow:var(--shadow-sm);transition:all 0.2s;';
                
                itemDiv.innerHTML = `
                    <div style="display:flex;flex-direction:column;align-items:center;margin-top:0.25rem;flex-shrink:0;">
                        <div style="font-size:0.6rem;font-weight:800;color:var(--text-muted);text-transform:uppercase;margin-bottom:2px;">Orden</div>
                        <div class="parada-index" style="width:24px;height:24px;border-radius:50%;background:var(--bg-subtle);border:1px solid var(--border-color);display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;color:var(--text-secondary);">${paradasCount + 1}</div>
                    </div>
                    
                    <div style="flex:1;min-width:0;display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                        <div>
                            <label style="font-size:0.7rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:0.2rem;">Nombre Parada</label>
                            <input type="text" class="form-control form-control-sm" name="Paradas[${paradasCount}].Nombre" placeholder="Ej: Parada 1" required style="font-weight:600;" />
                        </div>
                        <div>
                            <label style="font-size:0.7rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:0.2rem;">Ubicación / Referencia</label>
                            <input type="text" class="form-control form-control-sm" name="Paradas[${paradasCount}].Ubicacion" placeholder="Opcional" />
                        </div>
                    </div>
                    
                    <div style="width:120px;flex-shrink:0;">
                        <label style="font-size:0.7rem;font-weight:600;color:var(--text-muted);display:block;margin-bottom:0.2rem;">ETA (hh:mm)</label>
                        <input type="text" class="form-control form-control-sm" name="Paradas[${paradasCount}].TiempoDesdeOrigen" placeholder="00:00" required />
                        <input type="hidden" name="Paradas[${paradasCount}].Orden" value="${paradasCount + 1}" />
                    </div>

                    <button type="button" class="btn-remove-parada" title="Quitar parada"
                            style="margin-top:0.2rem;flex-shrink:0;background:none;border:none;color:var(--text-muted);cursor:pointer;padding:0.25rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><line x1="8" y1="12" x2="16" y2="12"/>
                        </svg>
                    </button>
                `;
                
                itemDiv.addEventListener('mouseenter', () => { 
                    itemDiv.style.borderColor = 'var(--border-strong)';
                    itemDiv.querySelector('.btn-remove-parada').style.color = 'var(--danger)';
                });
                itemDiv.addEventListener('mouseleave', () => {
                    itemDiv.style.borderColor = 'var(--border-color)';
                    itemDiv.querySelector('.btn-remove-parada').style.color = 'var(--text-muted)';
                });

                container.appendChild(itemDiv);
                paradasCount++;

                itemDiv.querySelector('.btn-remove-parada').addEventListener('click', function() {
                    itemDiv.remove();
                    reindexParadas();
                });
            });

            function reindexParadas() {
                const items = container.querySelectorAll('.parada-item');
                paradasCount = items.length;
                if(paradasCount === 0) {
                    emptyLabel.style.display = 'block';
                    return;
                }
                
                items.forEach((item, index) => {
                    item.querySelector('.parada-index').innerText = index + 1;
                    item.querySelectorAll('input').forEach(input => {
                        const name = input.getAttribute('name');
                        if(name) {
                            input.setAttribute('name', name.replace(/\[\d+\]/, `[${index}]`));
                        }
                        if(name && name.includes('Orden')) {
                            input.value = index + 1;
                        }
                    });
                });
            }
        });
    </script>
}
