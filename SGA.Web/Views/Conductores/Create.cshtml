@using SGA.Web.ViewModels.Conductores
@model ConductorFormViewModel
@{ ViewData["Title"] = "Nuevo Conductor"; }

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="form-card">
            <div class="form-card-header"><h5>Registrar Conductor</h5></div>
            <form asp-action="Create" method="post">
                <div class="form-card-body">
                    <div asp-validation-summary="All" class="alert alert-danger alert-sm"></div>
                    <h6 class="text-muted mb-3">Datos Personales</h6>
                    <div class="row g-3">
                        <div class="col-md-6"><label asp-for="Nombre" class="form-label"></label><input asp-for="Nombre" class="form-control" /><span asp-validation-for="Nombre" class="text-danger small"></span></div>
                        <div class="col-md-6"><label asp-for="Apellido" class="form-label"></label><input asp-for="Apellido" class="form-control" /><span asp-validation-for="Apellido" class="text-danger small"></span></div>
                        <div class="col-md-6"><label asp-for="DocumentoIdentidad" class="form-label"></label><input asp-for="DocumentoIdentidad" class="form-control" /><span asp-validation-for="DocumentoIdentidad" class="text-danger small"></span></div>
                        <div class="col-md-6"><label asp-for="Telefono" class="form-label"></label><input asp-for="Telefono" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="Contrasena" class="form-label"></label><input asp-for="Contrasena" class="form-control" type="password" placeholder="Establecer contraseña" /></div>
                        <div class="col-12"><label asp-for="Direccion" class="form-label"></label><input asp-for="Direccion" class="form-control" /></div>
                    </div>
                    <hr class="my-4" />
                    <h6 class="text-muted mb-3">Datos de Conductor</h6>
                    <div class="row g-3">
                        <div class="col-md-6"><label asp-for="LicenciaConducir" class="form-label"></label><input asp-for="LicenciaConducir" class="form-control" /><span asp-validation-for="LicenciaConducir" class="text-danger small"></span></div>
                        <div class="col-md-6"><label asp-for="CategoriaLicencia" class="form-label"></label><input asp-for="CategoriaLicencia" class="form-control" placeholder="Ej: B, D, E" /></div>
                        <div class="col-md-6"><label asp-for="FechaVencimientoLicencia" class="form-label"></label><input asp-for="FechaVencimientoLicencia" class="form-control" type="date" /></div>
                        <div class="col-md-6"><label asp-for="FechaContratacion" class="form-label"></label><input asp-for="FechaContratacion" class="form-control" type="date" /></div>
                    </div>
                </div>
                <div class="form-card-footer">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Registrar Conductor</button>
                </div>
            </form>
        </div>
    </div>
</div>
