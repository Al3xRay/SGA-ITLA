@using SGA.Web.ViewModels.Autobuses
@model AutobusFormViewModel
@{ ViewData["Title"] = "Editar Autobús"; }

<div class="page-header">
    <div class="page-header-title">
        <h2>Editar Autobús</h2>
        <p>Placa: <strong style="color:var(--primary-mid);">@Model.Placa</strong></p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3rem;">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Volver
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="form-card">
            <div class="form-card-header">
                <div class="icon-badge icon-badge-warning">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                </div>
                <h5>Modificar Datos del Vehículo</h5>
            </div>
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post" id="form-edit-autobus">
                <div class="form-card-body">
                    <div asp-validation-summary="All" class="alert alert-danger alert-sm" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Placa" class="form-label">Placa</label>
                            <input asp-for="Placa" class="form-control" readonly style="opacity:0.65;" />
                            <small style="color:var(--text-muted);font-size:0.75rem;">La placa no puede modificarse una vez registrada.</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Marca" class="form-label">Marca</label>
                            <input asp-for="Marca" class="form-control" />
                            <span asp-validation-for="Marca" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Modelo" class="form-label">Modelo</label>
                            <input asp-for="Modelo" class="form-control" />
                            <span asp-validation-for="Modelo" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Capacidad" class="form-label">Capacidad</label>
                            <input asp-for="Capacidad" class="form-control" type="number" />
                            <span asp-validation-for="Capacidad" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EstadoAutobusId" class="form-label">Estado Operativo</label>
                            <select asp-for="EstadoAutobusId" class="form-select" id="select-estado-autobus">
                                <option value="1">Disponible</option>
                                <option value="2">En Mantenimiento</option>
                                <option value="3">Fuera de Servicio</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="form-card-footer">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary" id="btn-guardar-autobus">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
