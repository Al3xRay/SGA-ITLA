@using SGA.Web.Models.Operaciones
@model AuditoriaGeneralDto
@{
    ViewData["Title"] = "Dashboard";
    var role     = ViewBag.Role as string ?? "Estudiante";
    var userName = ViewBag.UserName as string ?? "Usuario";
    var hour     = DateTime.Now.Hour;
    var greeting = hour < 12 ? "Buenos días" : (hour < 18 ? "Buenas tardes" : "Buenas noches");
}

<div class="welcome-banner">
    <div style="position:relative; z-index:1;">
        <p class="welcome-greeting">@greeting</p>
        <h2 class="welcome-name">@userName</h2>
        <p class="welcome-desc">
            @if (role == "Administrador")
            {
                <span>Panel de administración — Sistema de Gestión de Autobuses</span>
            }
            else if (role == "Conductor")
            {
                <span>Portal del conductor — Horario y gestión de rutas asignadas</span>
            }
            else
            {
                <span>Tu servicio de transporte institucional del ITLA</span>
            }
        </p>
    </div>
</div>
@if (role == "Administrador")
{
    <!-- KPIs -->
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="stat-card stat-primary">
                <div class="stat-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 11h18"/>
                        <circle cx="7" cy="19" r="1.5" fill="currentColor" stroke="none"/>
                        <circle cx="17" cy="19" r="1.5" fill="currentColor" stroke="none"/>
                    </svg>
                </div>
                <div class="stat-info-content">
                    <span class="stat-label">Autobuses Activos</span>
                    <span class="stat-value">@(Model?.AutobusesActivos ?? 0)</span>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="stat-card stat-success">
                <div class="stat-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="10" r="3"/>
                        <path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 10-16 0c0 3 2.7 7 8 11.7z"/>
                    </svg>
                </div>
                <div class="stat-info-content">
                    <span class="stat-label">Rutas</span>
                    <span class="stat-value">@(Model?.RutasTotales ?? 0)</span>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="stat-card stat-info">
                <div class="stat-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                </div>
                <div class="stat-info-content">
                    <span class="stat-label">Viajes Programados</span>
                    <span class="stat-value">@(Model?.ViajesProgramados ?? 0)</span>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="stat-card stat-danger">
                <div class="stat-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                </div>
                <div class="stat-info-content">
                    <span class="stat-label">Incidencias Pendientes</span>
                    <span class="stat-value">@(Model?.IncidenciasPendientes ?? 0)</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Accesos Rápidos SOLO Admin -->
    <div class="content-card">
        <div class="content-card-header">
            <h5>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.4rem;color:var(--primary-mid);">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
                Accesos Rápidos
            </h5>
        </div>
        <div class="content-card-body">
            <div class="row g-3">
                <div class="col-md-3 col-sm-6">
                    <a asp-controller="Viajes" asp-action="Index" class="quick-action" id="qa-viajes">
                        <div class="qa-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                        </div>
                        <span>Control de Viajes</span>
                    </a>
                </div>
                <div class="col-md-3 col-sm-6">
                    <a asp-controller="Personas" asp-action="Index" class="quick-action" id="qa-personas">
                        <div class="qa-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
                            </svg>
                        </div>
                        <span>Gestión de Personas</span>
                    </a>
                </div>
                <div class="col-md-3 col-sm-6">
                    <a asp-controller="Autorizaciones" asp-action="Create" class="quick-action" id="qa-ticket">
                        <div class="qa-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/>
                            </svg>
                        </div>
                        <span>Emitir Ticket / Tarjeta</span>
                    </a>
                </div>
                <div class="col-md-3 col-sm-6">
                    <a asp-controller="Finanzas" asp-action="Index" class="quick-action" id="qa-finanzas">
                        <div class="qa-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="12" y1="1" x2="12" y2="23"/>
                                <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                            </svg>
                        </div>
                        <span>Finanzas y Caja</span>
                    </a>
                </div>
                <div class="col-md-3 col-sm-6">
                    <a asp-controller="Autobuses" asp-action="Index" class="quick-action" id="qa-autobuses">
                        <div class="qa-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 11h18"/>
                                <circle cx="7" cy="19" r="1.5" fill="currentColor" stroke="none"/>
                                <circle cx="17" cy="19" r="1.5" fill="currentColor" stroke="none"/>
                            </svg>
                        </div>
                        <span>Flota de Autobuses</span>
                    </a>
                </div>
                <div class="col-md-3 col-sm-6">
                    <a asp-controller="Conductores" asp-action="Index" class="quick-action" id="qa-conductores">
                        <div class="qa-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                            </svg>
                        </div>
                        <span>Conductores</span>
                    </a>
                </div>
                <div class="col-md-3 col-sm-6">
                    <a asp-controller="Rutas" asp-action="Index" class="quick-action" id="qa-rutas">
                        <div class="qa-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="10" r="3"/>
                                <path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 10-16 0c0 3 2.7 7 8 11.7z"/>
                            </svg>
                        </div>
                        <span>Rutas y Paradas</span>
                    </a>
                </div>
                <div class="col-md-3 col-sm-6">
                    <a asp-controller="Auditoria" asp-action="Index" class="quick-action" id="qa-auditoria">
                        <div class="qa-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
                            </svg>
                        </div>
                        <span>Registro de Auditoría</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
}

@if (role == "Estudiante" || role == "Empleado")
{
    <div class="row g-3 mb-4">
        <!-- KPI — Saldo -->
        <div class="col-md-6">
            <div class="stat-card kpi-card-primary" style="min-height:130px;">
                <div class="stat-icon" style="background:rgba(255,255,255,0.15);color:white;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/>
                    </svg>
                </div>
                <div class="stat-info-content" style="position:relative;z-index:1;">
                    <span class="stat-label" style="color:rgba(255,255,255,0.65);">Saldo Disponible</span>
                    <span class="stat-value" style="color:white;font-size:2rem;">@ViewBag.Saldo</span>
                </div>
            </div>
        </div>
        <!-- KPI — Viajes Restantes -->
        <div class="col-md-6">
            <div class="stat-card stat-success" style="min-height:130px;">
                <div class="stat-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                </div>
                <div class="stat-info-content">
                    <span class="stat-label">Viajes Restantes</span>
                    <span class="stat-value">@ViewBag.ViajesRestantes</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Accesos rápidos SOLO Estudiante/Empleado -->
    <div class="content-card">
        <div class="content-card-header">
            <h5>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.4rem;color:var(--primary-mid);">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
                Accesos Rápidos
            </h5>
        </div>
        <div class="content-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <a asp-controller="Billetera" asp-action="Index" class="quick-action" id="qa-billetera">
                        <div class="qa-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/>
                                <path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/>
                                <path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/>
                            </svg>
                        </div>
                        <span>Ver Mi Billetera</span>
                    </a>
                </div>
                <div class="col-md-6">
                    <a asp-controller="Rutas" asp-action="Publicas" class="quick-action" id="qa-rutas-pub">
                        <div class="qa-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="10" r="3"/>
                                <path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 10-16 0c0 3 2.7 7 8 11.7z"/>
                            </svg>
                        </div>
                        <span>Consultar Rutas y Horarios</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
}

