@using SGA.Web.Helpers
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SGA-ITLA — Sistema de Gestión de Autobuses del Instituto Tecnológico de las Américas" />
    <title>@ViewData["Title"] — SGA-ITLA</title>

    <!-- Fuentes: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Bootstrap-->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Design System SGA-ITLA -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="app-container">

        <!-- ─── Sidebar ─── -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <a asp-controller="Home" asp-action="Index" class="sidebar-brand">
                    <div class="sidebar-brand-icon">
                        <!-- Bus icon -->
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="6" width="18" height="13" rx="2"/>
                            <path d="M3 11h18"/>
                            <circle cx="7" cy="19" r="1.5" fill="white" stroke="none"/>
                            <circle cx="17" cy="19" r="1.5" fill="white" stroke="none"/>
                            <path d="M8 6V4"/>
                            <path d="M16 6V4"/>
                        </svg>
                    </div>
                    <div class="sidebar-brand-text">
                        <span class="sidebar-brand-name">SGA-ITLA</span>
                        <span class="sidebar-brand-tagline">Transporte Institucional</span>
                    </div>
                </a>
            </div>

            <nav class="sidebar-nav">
                <partial name="_Sidebar" />
            </nav>

            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <div class="sidebar-user-avatar">
                        @(Context.Session.GetString(SessionKeys.UserName)?[..1].ToUpper() ?? "U")
                    </div>
                    <div class="sidebar-user-info">
                        <span class="sidebar-user-name">@Context.Session.GetString(SessionKeys.UserName)</span>
                        <span class="sidebar-user-role">@Context.Session.GetString(SessionKeys.UserRole)</span>
                    </div>
                </div>
                <a asp-controller="Auth" asp-action="Logout" class="sidebar-logout" title="Cerrar Sesión">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                </a>
            </div>
        </aside>

        <!-- ─── Main Content ─── -->
        <div class="main-content" id="mainContent">

            <!-- Top Navbar -->
            <header class="top-navbar">
                <button class="sidebar-toggle"
                        id="sidebarToggleBtn"
                        onclick="toggleSidebar()"
                        type="button"
                        aria-label="Alternar menú lateral">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="3" y1="12" x2="21" y2="12"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <line x1="3" y1="18" x2="21" y2="18"/>
                    </svg>
                </button>

                <h1 class="page-title">@ViewData["Title"]</h1>

                <div class="top-navbar-right">
                    <span class="badge-role">@Context.Session.GetString(SessionKeys.UserRole)</span>
                </div>
            </header>

            <!-- Alerts -->
            <div style="padding: 0 1.75rem; margin-top: 0.75rem;">
                <partial name="_Alerts" />
            </div>

            <!-- Page Content -->
            <main class="page-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const main = document.getElementById('mainContent');
            sidebar.classList.toggle('collapsed');
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
