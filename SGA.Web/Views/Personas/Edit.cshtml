@using SGA.Web.ViewModels.Personas
@model PersonaFormViewModel
@{ ViewData["Title"] = "Editar Persona"; }

<div class="page-header">
    <div class="page-header-title">
        <h2>Editar Persona</h2>
        <p>Actualiza la información del usuario</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3rem;">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Volver
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="form-card">
            <div class="form-card-header">
                <div class="icon-badge icon-badge-warning">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                </div>
                <h5>Modificar Datos</h5>
            </div>
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post" id="form-edit-persona">
                <div class="form-card-body">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="TipoPersonaId" />
                    <div asp-validation-summary="All" class="alert alert-danger alert-sm" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label">Nombre</label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Apellido" class="form-label">Apellido</label>
                            <input asp-for="Apellido" class="form-control" />
                            <span asp-validation-for="Apellido" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="DocumentoIdentidad" class="form-label"></label>
                            <input asp-for="DocumentoIdentidad" class="form-control" readonly style="opacity:0.65; background-color: var(--bg-subtle);" />
                            <small class="text-muted" style="font-size:0.75rem;">No se puede modificar una vez registrado.</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label">Teléfono</label>
                            <input asp-for="Telefono" class="form-control" placeholder="Ej: 809-000-0000" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Contrasena" class="form-label">Contraseña</label>
                            <input asp-for="Contrasena" class="form-control" type="text" placeholder="Dejar en blanco para mantener actual" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Direccion" class="form-label">Dirección</label>
                            <input asp-for="Direccion" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="form-card-footer">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary" id="btn-guardar-persona">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
