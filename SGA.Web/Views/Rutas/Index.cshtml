@using SGA.Web.ViewModels.Rutas
@model RutaListViewModel
@{ ViewData["Title"] = "Rutas"; }

<div class="page-header">
    <div class="page-header-title">
        <h2>Gestión de Rutas</h2>
        <p>Itinerarios, paradas y horarios del servicio de transporte ITLA</p>
    </div>
    <div class="page-header-actions">
        <div style="position:relative;">
            <input type="text" id="rutaSearchInput" class="form-control"
                   placeholder="Buscar origen, destino, parada..."
                   style="padding-left:2.25rem;min-width:220px;" />
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:var(--text-muted);">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
        </div>
        <a asp-action="Create" class="btn btn-primary" id="btn-nueva-ruta">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Nueva Ruta
        </a>
    </div>
</div>

@if (!Model.Rutas.Any())
{
    <div class="content-card">
        <div class="empty-state">
            <div class="empty-state-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 10-16 0c0 3 2.7 7 8 11.7z"/>
                </svg>
            </div>
            <h6>Sin rutas registradas</h6>
            <p>Crea la primera ruta para que el servicio de transporte pueda operar.</p>
            <a asp-action="Create" class="btn btn-primary btn-sm">Trazar primera ruta</a>
        </div>
    </div>
}
else
{
    <div class="row g-3" id="rutasList">
        @foreach (var item in Model.Rutas)
        {
            var collapseId = $"paradas_{item.Id}";
            <div class="col-xl-4 col-md-6 ruta-item">
                <div class="content-card" style="height:100%;display:flex;flex-direction:column;">

                    <!-- Header de la ruta -->
                    <div style="padding:1.125rem 1.25rem;border-bottom:1px solid var(--border-color);">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.5rem;margin-bottom:0.625rem;">
                            <div style="font-weight:700;font-size:0.9375rem;color:var(--text-primary);line-height:1.3;" class="ruta-search-text">
                                @item.Nombre
                            </div>
                            <span class="badge-status @(item.Activo ? "badge-activo" : "badge-inactivo")" style="flex-shrink:0;">
                                @(item.Activo ? "Activa" : "Suspendida")
                            </span>
                        </div>

                        <!-- Origen → Destino visual -->
                        <div style="display:flex;align-items:center;gap:0.5rem;padding:0.75rem;background:var(--bg-subtle);border-radius:var(--radius-sm);">
                            <div style="display:flex;flex-direction:column;align-items:center;gap:3px;flex-shrink:0;">
                                <div style="width:10px;height:10px;border-radius:50%;background:var(--success);box-shadow:0 0 0 2px var(--success-bg);"></div>
                                <div style="width:1.5px;height:22px;background:var(--border-strong);"></div>
                                <div style="width:10px;height:10px;border-radius:50%;background:var(--danger);box-shadow:0 0 0 2px var(--danger-bg);"></div>
                            </div>
                            <div style="display:flex;flex-direction:column;gap:0.5rem;flex:1;min-width:0;">
                                <div style="font-size:0.8125rem;font-weight:600;color:var(--text-primary);line-height:1.2;" class="ruta-search-text">@item.Origen</div>
                                <div style="font-size:0.8125rem;font-weight:600;color:var(--text-primary);line-height:1.2;" class="ruta-search-text">@item.Destino</div>
                            </div>
                        </div>
                    </div>

                    <!-- Meta de la ruta -->
                    <div style="padding:0.875rem 1.25rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border-color);">
                        <div style="display:flex;align-items:center;gap:0.375rem;font-size:0.8125rem;color:var(--text-secondary);">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                            </svg>
                            <span>~@item.DuracionEstimada.ToString(@"hh\:mm") hrs</span>
                        </div>
                        <div style="display:flex;align-items:center;gap:0.375rem;font-size:0.8125rem;color:var(--text-secondary);">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 10-16 0c0 3 2.7 7 8 11.7z"/>
                            </svg>
                            <span>@item.Paradas.Count() parada@(item.Paradas.Count() != 1 ? "s" : "")</span>
                        </div>
                    </div>

                    <!-- Paradas colapsables -->
                    @if (item.Paradas.Any())
                    {
                        <div style="padding:0.75rem 1.25rem;border-bottom:1px solid var(--border-color);">
                            <button type="button"
                                    onclick="toggleRutaParadas('@collapseId', this)"
                                    style="background:none;border:none;cursor:pointer;padding:0;font-size:0.8rem;font-weight:600;color:var(--primary-mid);display:flex;align-items:center;gap:0.35rem;width:100%;">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transition:transform 0.2s;" class="paradas-chevron">
                                    <polyline points="6 9 12 15 18 9"/>
                                </svg>
                                Ver itinerario
                            </button>
                            <div id="@collapseId" style="display:none;margin-top:0.75rem;">
                                <!-- Línea de tiempo vertical -->
                                <div style="position:relative;padding-left:1.25rem;">
                                    <div style="position:absolute;left:5px;top:6px;bottom:6px;width:1.5px;background:var(--border-strong);"></div>

                                    <div style="position:relative;margin-bottom:0.625rem;">
                                        <div style="position:absolute;left:-1.25rem;top:4px;width:10px;height:10px;border-radius:50%;background:var(--success);border:2px solid white;box-shadow:0 0 0 1.5px var(--success);"></div>
                                        <div style="font-size:0.8125rem;font-weight:700;color:var(--text-primary);" class="ruta-search-text">@item.Origen</div>
                                        <div style="font-size:0.7rem;color:var(--text-muted);">Salida · 00:00</div>
                                    </div>

                                    @foreach (var parada in item.Paradas.OrderBy(p => p.TiempoDesdeOrigen))
                                    {
                                        <div style="position:relative;margin-bottom:0.625rem;">
                                            <div style="position:absolute;left:-1.25rem;top:4px;width:8px;height:8px;border-radius:50%;background:var(--bg-card);border:2px solid var(--primary-mid);"></div>
                                            <div style="font-size:0.8125rem;font-weight:600;color:var(--text-primary);" class="ruta-search-text">@parada.Nombre</div>
                                            <div style="font-size:0.7rem;color:var(--text-muted);">@parada.Ubicacion · +@parada.TiempoDesdeOrigen.ToString(@"hh\:mm")</div>
                                        </div>
                                    }

                                    <div style="position:relative;margin-bottom:0;">
                                        <div style="position:absolute;left:-1.25rem;top:4px;width:10px;height:10px;border-radius:50%;background:var(--danger);border:2px solid white;box-shadow:0 0 0 1.5px var(--danger);"></div>
                                        <div style="font-size:0.8125rem;font-weight:700;color:var(--text-primary);" class="ruta-search-text">@item.Destino</div>
                                        <div style="font-size:0.7rem;color:var(--text-muted);">Llegada · +@item.DuracionEstimada.ToString(@"hh\:mm")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Footer acciones -->
                    <div style="padding:0.875rem 1.25rem;margin-top:auto;display:flex;gap:0.375rem;justify-content:flex-end;">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm" id="btn-editar-ruta-@item.Id">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                                <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                            </svg>
                            Editar
                        </a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline"
                              onsubmit="return confirm('¿Eliminar la ruta @item.Nombre?')">
                            <button type="submit" class="btn btn-sm btn-action btn-action-danger" id="btn-eliminar-ruta-@item.Id" title="Eliminar">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/>
                                    <path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/>
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        function toggleRutaParadas(id, btn) {
            const panel   = document.getElementById(id);
            const chevron = btn.querySelector('.paradas-chevron');
            const isOpen  = panel.style.display !== 'none';
            panel.style.display   = isOpen ? 'none' : 'block';
            chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
            btn.querySelector('span') && (btn.querySelector('span').textContent = isOpen ? 'Ver itinerario' : 'Ocultar itinerario');
            const textNode = [...btn.childNodes].find(n => n.nodeType === 3);
            if (textNode) textNode.textContent = isOpen ? ' Ver itinerario' : ' Ocultar itinerario';
        }

        document.getElementById("rutaSearchInput")?.addEventListener("keyup", function () {
            const f = this.value.toLowerCase();
            document.querySelectorAll(".ruta-item").forEach(card => {
                const texts = [...card.querySelectorAll(".ruta-search-text")]
                    .map(t => t.textContent.toLowerCase()).join(" ");
                card.style.display = texts.includes(f) ? "" : "none";
            });
        });
    </script>
}
