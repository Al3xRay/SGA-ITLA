@using SGA.Web.ViewModels.Personas
@model PersonaFormViewModel
@{ ViewData["Title"] = "Nueva Persona"; }

<div class="page-header">
    <div class="page-header-title">
        <h2>Registrar Persona</h2>
        <p>Agrega un nuevo usuario al directorio del sistema</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.3rem;">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        Volver
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="form-card">
            <div class="form-card-header">
                <div class="icon-badge icon-badge-primary">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                    </svg>
                </div>
                <h5>Datos Personales</h5>
            </div>
            <form asp-action="Create" method="post" id="form-create-persona">
                <div class="form-card-body">
                    <div asp-validation-summary="All" class="alert alert-danger alert-sm" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label">Nombre</label>
                            <input asp-for="Nombre" class="form-control" placeholder="Nombre(s)" />
                            <span asp-validation-for="Nombre" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Apellido" class="form-label">Apellido</label>
                            <input asp-for="Apellido" class="form-control" placeholder="Apellido(s)" />
                            <span asp-validation-for="Apellido" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DocumentoIdentidad" class="form-label">Documento / Matrícula</label>
                            <input asp-for="DocumentoIdentidad" class="form-control" placeholder="Ej: 2024-2270" />
                            <span asp-validation-for="DocumentoIdentidad" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TipoPersonaId" class="form-label">Tipo de Persona</label>
                            <select asp-for="TipoPersonaId" class="form-select" id="select-tipo-persona">
                                <option value="">— Seleccionar —</option>
                                <option value="1">Estudiante</option>
                                <option value="2">Empleado</option>
                            </select>
                            <span asp-validation-for="TipoPersonaId" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label">Teléfono <span style="color:var(--text-muted);font-weight:400;">(opcional)</span></label>
                            <input asp-for="Telefono" class="form-control" placeholder="Ej: 809-000-0000" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FechaNacimiento" class="form-label">Fecha de Nacimiento</label>
                            <input asp-for="FechaNacimiento" class="form-control" type="date" id="input-fecha-nac" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Contrasena" class="form-label">Contraseña</label>
                            <input asp-for="Contrasena" class="form-control" type="password" placeholder="Establecer contraseña temporal" />
                            <span asp-validation-for="Contrasena" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Direccion" class="form-label">Dirección <span style="color:var(--text-muted);font-weight:400;">(opcional)</span></label>
                            <input asp-for="Direccion" class="form-control" placeholder="Dirección de residencia" />
                        </div>
                    </div>
                </div>
                <div class="form-card-footer">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary" id="btn-registrar-persona">Registrar Persona</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
